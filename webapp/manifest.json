{
  "manifest_version": 3,
  "name": "FFXIV - Pose Image Embedder",
  "description": "Provided by: https://ffxiv.edb.tools / Tex Nevada \nAdds a Download button on xivarchive.com that embeds the mod preview image, author, and tags into .pose files before downloading.",
  "version": "1.0.0",
  "permissions": [],
  "host_permissions": [
    "https://www.xivmodarchive.com/*",
    "https://xivmodarchive.com/*",
    "https://static.xivmodarchive.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.xivmodarchive.com/*",
        "https://xivmodarchive.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "noreply@edb.tools",
      "strict_min_version": "109.0"
    }
  }
}